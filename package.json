{
  "name": "clockboard",
  "displayName": "Clockboard",
  "version": "0.1.0",
  "description": "Live digital clocks and countdowns for the browser new tab page.",
  "author": "Clockboard contributors",
  "license": "MIT",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "plasmo dev",
    "dev:edge": "plasmo dev --target=edge-mv3",
    "build": "plasmo build",
    "build:edge": "plasmo build --target=edge-mv3",
    "package": "plasmo package",
    "package:edge": "plasmo package --target=edge-mv3",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "e2e": "playwright test",
    "verify": "npm run typecheck && npm run test && npm run build"
  },
  "dependencies": {
    "@plasmohq/storage": "^1.15.0",
    "plasmo": "^0.90.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@types/chrome": "^0.0.309",
    "@types/node": "^22.15.18",
    "@types/react": "^18.3.20",
    "@types/react-dom": "^18.3.6",
    "http-server": "^14.1.1",
    "jsdom": "^26.1.0",
    "typescript": "^5.8.3",
    "vitest": "^3.1.3"
  },
  "manifest": {
    "manifest_version": 3,
    "name": "Clockboard",
    "short_name": "Clockboard",
    "version": "0.1.0",
    "description": "Live digital clocks and countdowns for your new tab page.",
    "minimum_chrome_version": "116",
    "permissions": [
      "storage"
    ],
    "action": {
      "default_title": "Clockboard",
      "default_popup": "popup.html"
    },
    "chrome_url_overrides": {
      "newtab": "newtab.html"
    },
    "options_ui": {
      "page": "options.html",
      "open_in_tab": true
    },
    "icons": {
      "16": "../assets/icon16.png",
      "32": "../assets/icon32.png",
      "48": "../assets/icon48.png",
      "128": "../assets/icon128.png"
    }
  }
}
