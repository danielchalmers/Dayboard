{
  "name": "clockboard",
  "version": "0.1.0",
  "private": true,
  "description": "A clean new tab clock and countdown dashboard for desktop browsers.",
  "license": "MIT",
  "author": "Daniel Chalmers",
  "type": "module",
  "engines": {
    "node": ">=24.0.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "clean": "rimraf dist artifacts coverage playwright-report test-results",
    "dev": "vite --host 127.0.0.1",
    "build": "npm run build:chromium && npm run build:firefox",
    "build:chromium": "vite build --mode chromium",
    "build:firefox": "vite build --mode firefox",
    "icons": "node scripts/generate-icons.mjs",
    "package": "npm run build && node scripts/package-extension.mjs",
    "package:chromium": "npm run build:chromium && node scripts/package-extension.mjs chromium",
    "package:firefox": "npm run build:firefox && node scripts/package-extension.mjs firefox",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "svelte-check --tsconfig ./tsconfig.json",
    "test": "npm run test:unit && npm run test:e2e",
    "test:unit": "vitest run",
    "test:e2e": "playwright test",
    "screenshots": "playwright test tests/e2e/screenshots.spec.ts --project=chromium"
  },
  "dependencies": {
    "svelte": "^5.39.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@playwright/test": "^1.49.1",
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "@testing-library/svelte": "^5.2.6",
    "@types/archiver": "^6.0.3",
    "@types/chrome": "^0.0.287",
    "@types/node": "^24.0.0",
    "@types/pngjs": "^6.0.5",
    "archiver": "^7.0.1",
    "eslint": "^9.17.0",
    "eslint-plugin-svelte": "^2.46.1",
    "globals": "^15.14.0",
    "jsdom": "^25.0.1",
    "pngjs": "^7.0.0",
    "prettier": "^3.4.2",
    "prettier-plugin-svelte": "^3.3.3",
    "rimraf": "^6.0.1",
    "svelte-check": "^4.1.1",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.2",
    "vite": "^7.3.3",
    "vitest": "^4.1.5"
  }
}
