{
  "extends": "./.wxt/tsconfig.json",
  "compilerOptions": {
    "jsx": "react-jsx",
    "types": [
      "chrome",
      "node",
      "vitest/globals",
      "@testing-library/jest-dom"
    ],
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true
  },
  "include": [
    "src/**/*",
    "test/**/*",
    "e2e/**/*",
    "wxt.config.ts",
    "playwright.config.ts",
    "vitest.config.ts",
    ".wxt/wxt.d.ts"
  ]
}
