{
  "extends": "./tsconfig.node.json",
  "compilerOptions": {
    "allowJs": false,
    "checkJs": false,
    "isolatedModules": true,
    "moduleResolution": "bundler",
    "strict": true,
    "types": ["chrome", "vite/client", "vitest/globals"]
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.svelte",
    "scripts/**/*.mjs",
    "tests/**/*.ts",
    "vite.config.ts"
  ]
}
